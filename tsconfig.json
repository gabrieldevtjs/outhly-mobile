{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "experimentalDecorators": true,
    "paths": {
      "@assets/*": ["./assets/*"],
      "@components/*": ["./src/common/components/*"],
      "@screens/*": ["./src/screens/*"],
      "@common/*": ["./src/common/*"],
      "@api/*": ["./src/infrastructure/config/http/axios/*"],
      "@routes/*": ["./src/routes/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "tamagui.config.ts", "global.d.ts"]
}
